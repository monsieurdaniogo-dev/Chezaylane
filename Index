<script>
  function setLang(lang) {
    document.body.classList.toggle('en', lang === 'en');
    document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.toggle('active', btn.textContent === lang.toUpperCase()));
  }
  function submitForm(e) {
    e.preventDefault();
    const isFr = !document.body.classList.contains('en');
    alert(isFr ? 'Merci ! Nous vous contacterons très bientôt pour confirmer votre réservation.' : 'Thank you! We will contact you shortly to confirm your booking.');
  }
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'translateY(0)'; } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.tarif-card, .location-item, .feature-item').forEach(el => {
    el.style.opacity = '0'; el.style.transform = 'translateY(20px)'; el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
    observer.observe(el);
  });
</script>

